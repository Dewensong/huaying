# 服务配置
PORT=3002
NODE_ENV=production

# ffmpeg 路径配置
# Mac 本地: /Users/zhangdongtao/bin/ffmpeg
# Linux 服务器: /usr/bin/ffmpeg
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# JWT 密钥
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# 腾讯云 COS
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your_cos_bucket
COS_REGION=ap-beijing
COS_APP_ID=your_app_id

# 火山方舟 AI
ARK_API_KEY=your_ark_api_key
ARK_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_MODEL=doubao-seed-1-6-251015

# 火山方舟 Seedream 图片生成 API
ARK_IMAGE_API_KEY=your_image_api_key
ARK_IMAGE_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/images/generations
ARK_IMAGE_MODEL=doubao-seedream-4-0-250828

# 商业化配置
FREE_CREDITS=99999
DEFAULT_PLAN=free

# 腾讯混元3D API 密钥
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
HUNYUAN3D_REGION=ap-beijing
TENCENT_API_KEY=your_tencent_api_key

# 第三方 API 超时时间（毫秒）
THIRD_PARTY_TIMEOUT=120000

# 火山方舟 TTS 语音合成 API
VOLCANO_TTS_APP_ID=your_app_id
VOLCANO_TTS_ACCESS_KEY=your_access_key

VOLCANO_SPEECH_API_KEY=your_speech_api_key

ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_SMS_SIGN_NAME=速通互联验证码
ALIYUN_SMS_TEMPLATE_CODE=100001
